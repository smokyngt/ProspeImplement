{
  "name": "prosperify-sdk",
  "version": "1.0.0",
  "description": "A TypeScript SDK for consuming the Prosperify API.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "jest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "prepare": "npm run build",
    "generate": "openapi --input ./openapi.json --output ./src/generated --client fetch"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yourusername/prosperify-sdk.git"
  },
  "keywords": [
    "prosperify",
    "sdk",
    "typescript",
    "api"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "axios": "^0.21.1"
  },
  "devDependencies": {
    "@types/jest": "^26.0.0",
    "@types/node": "^14.0.0",
    "typescript": "^4.0.0",
    "eslint": "^7.0.0",
    "prettier": "^2.0.0",
    "jest": "^26.0.0",
    "rollup": "^2.0.0",
    "rollup-plugin-typescript2": "^0.27.0",
    "openapi-typescript-codegen": "^0.25.0"
  }
}
